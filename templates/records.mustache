<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>体重記録</title>
</head>
<body>
  <h1>体重記録</h1>
  <p>ようこそ、{{username}} さん</p>
  <a href="/logout">ログアウト</a>

  <h2>記録する</h2>
  <form method="post" action="/records">
    <label>体重 (kg)<br>
      <input type="number" step="0.1" name="weight" required>
    </label><br><br>
    <button type="submit">保存</button>
  </form>

  <h2>記録一覧</h2>
  {{#hasRecords}}
  <table border="1" cellpadding="8">
    <thead>
      <tr><th>日時</th><th>体重 (kg)</th></tr>
    </thead>
    <tbody>
      {{#records}}
      <tr>
        <td>{{time}}</td>
        <td>{{weight}}</td>
      </tr>
      {{/records}}
    </tbody>
  </table>
  {{/hasRecords}}
  {{^hasRecords}}
  <p>まだ記録がありません。</p>
  {{/hasRecords}}
</body>
</html>
